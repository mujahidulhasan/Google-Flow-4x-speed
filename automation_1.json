              "name": "key",
              "value": "YOUR_YOUTUBE_API_KEY"
            }
          ]
        }
      },
      "id": "get_latest_uploads",
      "name": "Get Latest Uploads",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1200,
        300
      ]
    },
    {
      "parameters": {
        "functionCode": "const videos = items[0].json.items || [];\n\nreturn videos.map(video => {\n  return {\n    json: {\n      title: video.snippet.title,\n      description: video.snippet.description,\n      publishedAt: video.snippet.publishedAt,\n      thumbnail: video.snippet.thumbnails.high.url,\n      videoId: video.id.videoId,\n      channelTitle: video.snippet.channelTitle\n    }\n  };\n});"
      },
      "id": "extract_video_data",
      "name": "Extract Video Data",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        1450,
        300
      ]
    },
    {
      "parameters": {
        "authentication": "none",
        "url": "https://www.googleapis.com/youtube/v3/videos",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "part",
              "value": "statistics"
            },
            {
              "name": "id",
              "value": "={{$json[\"videoId\"]}}"
            },
            {
              "name": "key",
              "value": "YOUR_YOUTUBE_API_KEY"
            }
          ]
        }
      },
      "id": "video_statistics",
      "name": "Get Video Statistics",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1700,
        300
      ]
    },
    {
      "parameters": {
        "functionCode": "const stats = items[0].json.items[0].statistics;\n\nconst views = Number(stats.viewCount || 0);\n\nconst published = new Date($json.publishedAt || new Date());\nconst now = new Date();\n\nconst hoursAgo = Math.max(1, (now - published) / 3600000);\n\nconst velocity = Math.floor(views / hoursAgo);\n\nlet trend = 'low';\n\nif (velocity > 50000) trend = 'exploding';\nelse if (velocity > 10000) trend = 'strong';\nelse if (velocity > 3000) trend = 'growing';\n\nreturn [{\n  json: {\n    ...$json,\n    views,\n    velocity,\n    trend\n  }\n}];"
      },
      "id": "calculate_velocity",
      "name": "Calculate Trend Velocity",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        1950,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer YOUR_OPENROUTER_API_KEY"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"google/gemini-2.0-flash-exp:free\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an elite YouTube trend analysis AI.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Analyze this YouTube Shorts video. Find hook psychology, emotional trigger, thumbnail psychology, cliffhanger pattern, why viewers clicked, retention possibility, trend potential, and unexplored opportunity. Title: {{$json[\\\"title\\\"]}} Trend Status: {{$json[\\\"trend\\\"]}} Views: {{$json[\\\"views\\\"]}}\"\n    }\n  ]\n}"
      },
      "id": "gemini_analysis",
      "name": "Gemini Trend Analysis",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        2200,
        300
      ]
    },
    {
      "parameters": {
        "chatId": "YOUR_TELEGRAM_CHAT_ID",
        "text": "🔥 TREND DETECTED\n\nChannel: {{$json[\"channelTitle\"]}}\n\nTitle: {{$json[\"title\"]}}\n\nViews: {{$json[\"views\"]}}\n\nVelocity: {{$json[\"velocity\"]}}\n\nTrend: {{$json[\"trend\"]}}\n\nAI Analysis:\n{{$json[\"choices\"][0][\"message\"][\"content\"]}}"
      },
      "id": "telegram_report",
      "name": "Telegram Trend Report",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [
        2450,
        300
      ]
    }
