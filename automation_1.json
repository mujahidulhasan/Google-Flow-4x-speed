    {
      "parameters": {
        "functionCode": "const channels = items[0].json.items || [];\n\nreturn channels.map(channel => {\n  return {\n    json: {\n      channelTitle: channel.snippet.title,\n      channelId: channel.snippet.resourceId.channelId\n    }\n  };\n});"
      },
      "id": "extract_channels",
      "name": "Extract Channel IDs",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        700,
        300
      ]
    },
    {
      "parameters": {
        "batchSize": 1
      },
