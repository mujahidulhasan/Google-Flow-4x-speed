    {
      "parameters": {
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googleOAuth2Api",
        "url": "https://www.googleapis.com/youtube/v3/subscriptions",
        "sendQuery": true,
        "queryParameters": {
